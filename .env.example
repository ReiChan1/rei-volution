# ============================================================================
# REQUIRED: replace EVERY value below with your own — none of these will
# work as-is. The hostnames/passwords here are examples, not real servers.
# ============================================================================

# Where to find your real values:
#   Supabase Dashboard -> your project -> "Connect" button (top of page)
#   -> "ORMs" tab -> Prisma. It shows both strings below, pre-filled with
#   your actual project. Copy them EXACTLY, then replace [YOUR-PASSWORD]
#   with your real database password.
#
# If your password contains special characters (@ # % & etc.), they must
# be percent-encoded — e.g. "p@ss" becomes "p%40ss". Supabase's own copy
# button in the ORMs tab does this for you automatically, so prefer
# copy-pasting from there over typing it by hand.

# DATABASE_URL = pooled "Transaction" connection, port 6543, used by the app
DATABASE_URL="postgresql://postgres.REPLACE_WITH_YOUR_PROJECT_REF:REPLACE_WITH_YOUR_PASSWORD@REPLACE_WITH_YOUR_POOLER_HOST.pooler.supabase.com:6543/postgres?pgbouncer=true"

# DIRECT_URL = direct "Session" connection, port 5432, used only for migrations
DIRECT_URL="postgresql://postgres.REPLACE_WITH_YOUR_PROJECT_REF:REPLACE_WITH_YOUR_PASSWORD@REPLACE_WITH_YOUR_POOLER_HOST.pooler.supabase.com:5432/postgres"

# Generate a real secret with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"
